<!-- pages/detail/detail.wxml -->
<view wx:if="{{detail}}" class="page">

  <!-- 头部 -->
  <view class="header-card">
    <view class="cat-badge">{{detail.cat}}</view>
    <text class="title">{{detail.sku_id}}</text>
    <view class="score-row">
      <view class="score-main">
        <text class="score-num">{{detail.score_text}}</text>
        <text class="score-label">综合推荐分</text>
      </view>
      <view class="score-sub">
        <text class="sent-num {{detail.sent_class}}">{{detail.sent_text}}</text>
        <text class="score-label">方面情感均值</text>
      </view>
    </view>
  </view>

  <!-- 情感分布 -->
  <view class="card">
    <view class="card-title-row">
      <text class="card-title">情感分布</text>
      <text class="card-tag">{{detail.absa_comment_count}} 条评论</text>
    </view>
    <view class="dist-bar">
      <view class="seg seg-pos" style="width:{{detail.pos_bar+'%'}}"></view>
<view class="seg seg-neu" style="width:{{detail.neu_bar+'%'}}"></view>
<view class="seg seg-neg" style="width:{{detail.neg_bar+'%'}}"></view>
    </view>
    <view class="dist-legend">
      <view class="leg-item">
        <view class="dot dot-pos"></view>
        <text>正向 {{detail.pos_text}}%</text>
      </view>
      <view class="leg-item">
        <view class="dot dot-neu"></view>
        <text class="neu">中性 {{detail.neu_text}}%</text>
      </view>
      <view class="leg-item">
        <view class="dot dot-neg"></view>
        <text class="neg">负向 {{detail.neg_text}}%</text>
      </view>
    </view>

    <!-- 指标网格 -->
    <view class="metrics-grid">
      <view class="metric-cell">
        <text class="cell-label">方面情感均值</text>
        <text class="cell-value {{detail.sent_class}}">{{detail.sent_text}}</text>
      </view>
      <view class="metric-cell">
        <text class="cell-label">方面强度均值</text>
        <text class="cell-value">{{detail.abs_text}}</text>
      </view>
      <view class="metric-cell">
        <text class="cell-label">平均置信度</text>
        <text class="cell-value">{{detail.conf_text}}</text>
      </view>
      <view class="metric-cell">
        <text class="cell-label">方面覆盖率</text>
        <text class="cell-value">{{detail.known_text}}%</text>
      </view>
    </view>
  </view>

  <!-- 方面情感详情 -->
  <view class="card">
    <view class="card-title-row">
      <text class="card-title">各方面情感详情</text>
    </view>
    <view wx:if="{{aspects.length === 0}}" class="empty">暂无方面数据</view>
    <view wx:else>
      <view wx:for="{{aspects}}" wx:key="aspect" class="aspect-row">
        <view class="aspect-left">
          <text class="aspect-name">{{item.aspect}}</text>
          <text class="aspect-count">{{item.aspect_count}}条</text>
        </view>
        <view class="aspect-bar-wrap">
          <view class="aspect-bar">
            <view
              class="aspect-fill {{item.sent_class}}"
              style="width:{{item.bar_width+'%'}}"
            ></view>
          </view>
        </view>
        <text class="aspect-score {{item.sent_class}}">{{item.sent_text}}</text>
      </view>
    </view>
  </view>

</view>

<view wx:else class="page">
  <view class="empty-page">未找到商品数据</view>
</view>
