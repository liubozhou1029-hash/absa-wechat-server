/* pages/detail/detail.wxss */
.page { background: #f5f6fa; min-height: 100vh; padding-bottom: 40rpx; }
.empty-page { padding: 80rpx; text-align: center; color: #aaa; font-size: 28rpx; }

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  padding: 40rpx 28rpx 32rpx;
}
.cat-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
  line-height: 1.4;
}
.score-row { display: flex; gap: 32rpx; }
.score-main, .score-sub { text-align: center; }
.score-num {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}
.sent-num {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}
.pos-val { color: #fff; }
.neg-val { color: #ffcccc; }
.score-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
}

/* 通用卡片 */
.card {
  margin: 16rpx 20rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}
.card-title { font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.card-tag {
  font-size: 24rpx;
  color: #7c4dff;
  background: #f0f0ff;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* 情感分布条 */
.dist-bar {
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  background: #f0f0f0;
  margin-bottom: 12rpx;
}
.seg { height: 100%; }
.seg-pos { background: #4a9eff; }
.seg-neu { background: #e0e0e0; }
.seg-neg { background: #ff4757; }

.dist-legend { display: flex; gap: 20rpx; margin-bottom: 20rpx; }
.leg-item { display: flex; align-items: center; gap: 6rpx; font-size: 24rpx; color: #4a9eff; }
.leg-item .neu { color: #aaa; }
.leg-item .neg { color: #ff4757; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.dot-pos { background: #4a9eff; }
.dot-neu { background: #e0e0e0; }
.dot-neg { background: #ff4757; }

/* 指标网格 */
.metrics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 16rpx;
}
.metric-cell { text-align: center; }
.cell-label { display: block; font-size: 22rpx; color: #aaa; margin-bottom: 6rpx; }
.cell-value { display: block; font-size: 32rpx; font-weight: 600; color: #333; }

/* 方面详情列表 */
.empty { padding: 20rpx; text-align: center; color: #aaa; font-size: 26rpx; }
.aspect-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.aspect-row:last-child { border-bottom: none; }
.aspect-left { width: 120rpx; flex-shrink: 0; }
.aspect-name { display: block; font-size: 26rpx; color: #333; font-weight: 500; }
.aspect-count { display: block; font-size: 20rpx; color: #aaa; }
.aspect-bar-wrap { flex: 1; }
.aspect-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}
.aspect-fill { height: 100%; border-radius: 6rpx; }
.aspect-fill.pos-val { background: linear-gradient(90deg, #4a9eff, #7c4dff); }
.aspect-fill.neg-val { background: linear-gradient(90deg, #ff6b6b, #ff4757); }
.aspect-score {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}
