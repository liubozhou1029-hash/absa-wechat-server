.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ===== 头部卡片 ===== */
.header-card {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.22);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

/* ===== 新旧分数对比行 ===== */
.score-row {
  display: flex;
  gap: 24rpx;
  margin-top: 28rpx;
}

.score-box {
  flex: 1;
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
}

.score-box.primary {
  background: rgba(255, 255, 255, 0.22);
}

.score-box.secondary {
  background: rgba(255, 255, 255, 0.10);
}

.score-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.score-value {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.compare-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  opacity: 0.75;
  line-height: 1.6;
}

/* ===== 通用卡片 ===== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 68, 0.08);
}

/* 卡片标题行（标题 + 右侧角标） */
.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f2f5;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a44;
}

/* 情感指数角标 */
.card-score-badge {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.badge-label {
  font-size: 20rpx;
  color: #7b8794;
}

.badge-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #2563eb;
  line-height: 1.2;
}

/* 正/负向颜色 */
.value.pos-value { color: #16a34a; }
.value.neg-value { color: #dc2626; }

/* ===== 信息行 ===== */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f6f7fb;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 26rpx;
  color: #7b8794;
}

.value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2a44;
}

.value.highlight {
  color: #0f766e;
}

/* ===== 主题卡片 ===== */
.topic-item {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.topic-item:last-child {
  margin-bottom: 0;
}

.topic-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.topic-id {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2a44;
}

.topic-ratio {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}

.topic-keywords {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #475467;
  line-height: 1.7;
}

/* ===== ABSA 卡片专属样式 ===== */
.absa-card {
  border-top: 6rpx solid #2563eb;
}

.absa-tag {
  font-size: 22rpx;
  color: #2563eb;
  background: #eff6ff;
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
  font-weight: 600;
}

/* 情感分布条 */
.dist-bar-wrap {
  margin: 4rpx 0 24rpx;
}

.dist-bar {
  display: flex;
  height: 22rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f2f5;
}

.dist-seg { height: 100%; min-width: 2rpx; }
.seg-pos { background: #16a34a; }
.seg-neu { background: #d1d5db; }
.seg-neg { background: #dc2626; }

.dist-legend {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #475467;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-pos { background: #16a34a; }
.dot-neu { background: #d1d5db; }
.dot-neg { background: #dc2626; }

/* ABSA 指标 2×2 网格 */
.absa-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 8rpx;
}

.absa-cell {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
}

.absa-cell-label {
  font-size: 22rpx;
  color: #7b8794;
}

.absa-cell-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a44;
}

.absa-cell-value.highlight { color: #0f766e; }

/* ===== 空状态 ===== */
.empty {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #98a2b3;
}
