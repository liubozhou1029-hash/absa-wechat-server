<view class="page">
  <view class="page-header">
    <view class="page-title">商品推荐列表</view>
    <view class="page-subtitle">融合整体情感与方面级情感分析结果</view>
  </view>

  <view wx:if="{{loading}}" class="loading-box">
    <text class="loading-text">数据加载中...</text>
  </view>

  <block wx:else>
    <block wx:for="{{list}}" wx:key="sku_id">
      <view class="phone-card" bindtap="goDetail" data-sku="{{item.sku_id}}">

        <!-- 顶部：商品名 + 分数 -->
        <view class="card-top">
          <view class="name-block">
            <view class="name">{{item.display_name_text}}</view>
            <view class="sub-id">SKU: {{item.sku_id}}</view>
          </view>
          <view class="score-block">
            <view class="score-label">推荐分</view>
            <view class="score-value">{{item.score_text}}</view>
          </view>
        </view>

        <!-- 指标网格 -->
        <view class="metrics-grid">
          <view class="metric-item">
            <view class="metric-label">整体情感均值</view>
            <view class="metric-value">{{item.avg_sentiment_text}}</view>
          </view>
          <view class="metric-item" wx:if="{{item.has_absa}}">
            <view class="metric-label">方面情感均值</view>
            <view class="metric-value highlight">{{item.aspect_sentiment_mean_text}}</view>
          </view>
          <view class="metric-item" wx:if="{{item.has_absa}}">
            <view class="metric-label">方面正向比例</view>
            <view class="metric-value">{{item.aspect_positive_ratio_text}}%</view>
          </view>
          <view class="metric-item" wx:if="{{item.has_absa}}">
            <view class="metric-label">ABSA 评论数</view>
            <view class="metric-value">{{item.absa_comment_count_text}}</view>
          </view>
        </view>

        <!-- 底部：有效评论 -->
        <view class="bottom-row">
          <text>有效评论：{{item.effective_comments_text}}</text>
          <text>有效率：{{item.effective_ratio_text}}%</text>
        </view>

        <view class="go-detail">点击查看详情 ›</view>
      </view>
    </block>
  </block>
</view>