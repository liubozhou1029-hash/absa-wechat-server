/* pages/phones/phones.wxss */
.page { background: #f5f6fa; min-height: 100vh; padding-bottom: 40rpx; }

.page-header {
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  padding: 40rpx 28rpx 32rpx;
}
.page-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; }
.page-subtitle { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

.loading-box { padding: 80rpx; text-align: center; }
.loading-text { color: #aaa; font-size: 28rpx; }

/* 品类分组 */
.cat-section { margin-top: 24rpx; }

.cat-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx 12rpx;
}
.cat-dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  flex-shrink: 0;
}
.cat-name { font-size: 30rpx; font-weight: 700; color: #1a1a2e; flex: 1; }
.cat-count {
  font-size: 22rpx;
  color: #7c4dff;
  background: #f0f0ff;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* 推荐卡片 */
.rec-card {
  margin: 0 20rpx 12rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.card-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.rank-badge {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  color: #fff;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.name-block { flex: 1; overflow: hidden; }
.name {
  display: block;
  font-size: 28rpx; font-weight: 600; color: #1a1a2e;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.score-block { text-align: center; flex-shrink: 0; }
.score-num { display: block; font-size: 36rpx; font-weight: 700; color: #4a9eff; }
.score-label { display: block; font-size: 20rpx; color: #aaa; }

.dist-bar {
  height: 12rpx; border-radius: 6rpx;
  overflow: hidden; display: flex;
  background: #f0f0f0; margin-bottom: 8rpx;
}
.seg { height: 100%; }
.seg-pos { background: #4a9eff; }
.seg-neu { background: #e0e0e0; }
.seg-neg { background: #ff4757; }

.dist-legend { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.leg { font-size: 22rpx; }
.pos-text { color: #4a9eff; }
.neu-text { color: #aaa; }
.neg-text { color: #ff4757; }

.meta-row {
  display: flex;
  justify-content: space-between;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 10rpx;
}
.meta-item { font-size: 22rpx; color: #888; }
.tap-tip { color: #4a9eff; }

/* 品类筛选器 */
.cat-filter {
  position: sticky;
  top: 88rpx;  /* 搜索框高度 */
  z-index: 100;
  white-space: nowrap;
  background: #fff;
  padding: 12rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.cat-btn {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin-right: 10rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
}
.cat-btn.active {
  background: #4a9eff;
  color: #fff;
}



/* ── 搜索框 ── */
.search-wrap {
  position: sticky;
  top: 0;
  z-index: 101;  /* 比cat-filter高 */
  background: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.search-box {
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
  gap: 10rpx;
}
.search-icon { font-size: 28rpx; }
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}
.search-clear {
  font-size: 28rpx;
  color: #aaa;
  padding: 0 6rpx;
}
.search-result-tip {
  font-size: 24rpx;
  color: #aaa;
  padding: 12rpx 24rpx 4rpx;
}
.empty-box { padding: 60rpx; text-align: center; }
.empty-text { font-size: 28rpx; color: #aaa; }
.cat-tag-sm {
  display: inline-block;
  font-size: 20rpx;
  color: #7c4dff;
  background: #f0f0ff;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

/* ── 品类好评率概览图 ── */
.chart-card {
  margin: 16rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.chart-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}
.chart-list { display: flex; flex-direction: column; gap: 14rpx; }
.chart-row { display: flex; align-items: center; gap: 12rpx; }
.chart-cat {
  width: 80rpx;
  font-size: 24rpx;
  color: #555;
  flex-shrink: 0;
  text-align: right;
}
.chart-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.chart-bar-bg {
  flex: 1;
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}
.chart-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #4a9eff, #7c4dff);
  transition: width 0.5s;
}
.chart-val {
  width: 70rpx;
  font-size: 24rpx;
  color: #666;
  text-align: right;
  flex-shrink: 0;
}
.chart-val-high { color: #16a34a; font-weight: 700; }

/* 分享按钮（recommend页用）*/
.share-btn {
  margin: 0 20rpx 16rpx;
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
.share-btn::after { border: none; }
.share-icon { font-size: 32rpx; }
.share-text { font-size: 28rpx; color: #fff; }
