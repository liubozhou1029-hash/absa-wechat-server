.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-header {
  background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 45, 61, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2d3d;
  line-height: 1.4;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a8599;
  line-height: 1.6;
}

.loading,
.empty {
  text-align: center;
  color: #8a94a6;
  font-size: 28rpx;
  padding: 120rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 45, 61, 0.06);
  border: 1rpx solid #edf1f7;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2d3d;
  line-height: 1.5;
}

.rank-badge {
  flex-shrink: 0;
  min-width: 76rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #3b6ff5;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sku {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8a94a6;
}

.score-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.score-box {
  flex: 1;
  border-radius: 22rpx;
  padding: 22rpx 18rpx;
  text-align: center;
}

.score-box.primary {
  background: linear-gradient(135deg, #edf4ff 0%, #f5f9ff 100%);
}

.score-box.secondary {
  background: linear-gradient(135deg, #f7f8fb 0%, #fbfcfe 100%);
}

.score-label {
  font-size: 22rpx;
  color: #7a8599;
  line-height: 1.4;
}

.score-value {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #2f6bff;
  line-height: 1;
}

.metric-row {
  margin-top: 16rpx;
  background: #f8fafd;
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
}

.metric-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.metric-item + .metric-item {
  margin-top: 10rpx;
}

.metric-label {
  color: #7a8599;
}

.metric-value {
  color: #1f2d3d;
  font-weight: 600;
  text-align: right;
  word-break: break-all;
}

.tap-tip {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: #3b6ff5;
  font-weight: 600;
}