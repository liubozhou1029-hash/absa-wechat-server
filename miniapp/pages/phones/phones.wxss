.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2a44;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b8794;
}

.loading-box {
  padding: 120rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #7b8794;
}

/* ===== 商品卡片 ===== */
.phone-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 68, 0.08);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.name-block {
  flex: 1;
  margin-right: 20rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a44;
  line-height: 1.5;
  word-break: break-all;
}

.sub-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #98a2b3;
}

.score-block {
  min-width: 160rpx;
  text-align: right;
  flex-shrink: 0;
}

.score-label {
  font-size: 22rpx;
  color: #7b8794;
}

.score-value {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2563eb;
}

/* ===== 新旧对比行 ===== */
.compare-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 12rpx 18rpx;
  background: #eef4ff;
  border-radius: 12rpx;
}

.compare-item {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}

.compare-item.old {
  color: #7b8794;
  font-weight: 400;
}

.compare-sep {
  font-size: 22rpx;
  color: #98a2b3;
}

/* ===== 指标网格 ===== */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric-item {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 18rpx;
}

.metric-label {
  font-size: 22rpx;
  color: #7b8794;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2a44;
}

.metric-value.highlight {
  color: #0f766e;
}

/* ===== 底部行 ===== */
.bottom-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #667085;
}

.go-detail {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: #2563eb;
}
