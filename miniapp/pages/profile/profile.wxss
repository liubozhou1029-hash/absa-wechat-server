/* pages/profile/profile.wxss */
.page { background: #f5f6fa; min-height: 100vh; padding-bottom: 40rpx; }

.header {
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  padding: 50rpx 32rpx 36rpx;
}
.header-title { display: block; font-size: 44rpx; font-weight: 700; color: #fff; }
.header-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

/* 空状态 */
.empty-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 100rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 32rpx; font-weight: 600; color: #555; margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: #aaa; text-align: center; line-height: 1.8; }

/* 列表头 */
.record-list { padding: 20rpx; }
.list-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx; padding: 0 4rpx;
}
.list-title { font-size: 26rpx; color: #888; }
.clear-btn {
  padding: 8rpx 20rpx; border-radius: 16rpx;
  background: #fff0f0; border: 1rpx solid #fca5a5;
}
.clear-text { font-size: 24rpx; color: #ff4757; }

/* 记录卡片 */
.record-card {
  background: #fff; border-radius: 20rpx;
  padding: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.record-top {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 16rpx;
}
.record-time { font-size: 22rpx; color: #aaa; }
.cat-tag {
  font-size: 22rpx; color: #7c4dff;
  background: #f0f0ff; padding: 4rpx 14rpx; border-radius: 10rpx;
}

/* 评论区 */
.review-section { margin-bottom: 16rpx; }
.review-label {
  display: block; font-size: 22rpx; color: #aaa;
  margin-bottom: 8rpx; font-weight: 600;
}
.review-item {
  display: flex; gap: 8rpx; margin-bottom: 6rpx; align-items: flex-start;
}
.review-dot { font-size: 24rpx; color: #4a9eff; flex-shrink: 0; line-height: 1.6; }
.review-text {
  font-size: 24rpx; color: #555; line-height: 1.6;
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}

/* 推荐结果 */
.result-section {
  border-top: 1rpx solid #f0f0f0; padding-top: 14rpx;
}
.result-label {
  display: block; font-size: 22rpx; color: #aaa;
  margin-bottom: 10rpx; font-weight: 600;
}
.result-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 8rpx 0; border-bottom: 1rpx solid #f8f8f8;
}
.result-item:last-child { border-bottom: none; }
.result-rank {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  color: #fff; font-size: 20rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.result-name { flex: 1; font-size: 26rpx; color: #333; font-weight: 500; }
.result-cat {
  font-size: 20rpx; color: #7c4dff;
  background: #f0f0ff; padding: 3rpx 10rpx; border-radius: 8rpx;
}
.result-score { font-size: 24rpx; color: #4a9eff; font-weight: 600; flex-shrink: 0; }
