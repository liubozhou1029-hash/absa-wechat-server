<!-- pages/profile/profile.wxml -->
<view class="page">

  <view class="header">
    <text class="header-title">我的</text>
    <text class="header-sub">历史分析记录</text>
  </view>

  <view wx:if="{{records.length === 0}}" class="empty-box">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无历史记录</text>
    <text class="empty-hint">使用智能推荐后，记录将显示在这里</text>
  </view>

  <view wx:else class="record-list">
    <view class="list-header">
      <text class="list-title">共 {{records.length}} 条记录</text>
      <view class="clear-btn" bindtap="clearAll">
        <text class="clear-text">清空</text>
      </view>
    </view>

    <view
      wx:for="{{records}}"
      wx:key="time"
      class="record-card"
    >
      <!-- 时间 + 推断品类 -->
      <view class="record-top">
        <text class="record-time">{{item.time}}</text>
        <view wx:if="{{item.user_category}}" class="cat-tag">
          {{item.user_category}}
        </view>
      </view>

      <!-- 输入的评论 -->
      <view class="review-section">
        <text class="review-label">输入评论</text>
        <view wx:for="{{item.reviews}}" wx:key="*this" wx:for-item="rv" class="review-item">
          <text class="review-dot">·</text>
          <text class="review-text">{{rv}}</text>
        </view>
      </view>

      <!-- 推荐结果摘要 -->
      <view wx:if="{{item.top_results && item.top_results.length > 0}}" class="result-section">
        <text class="result-label">推荐结果</text>
        <view wx:for="{{item.top_results}}" wx:key="name" wx:for-item="rec" class="result-item">
          <text class="result-rank">{{index + 1}}</text>
          <text class="result-name">{{rec.name}}</text>
          <text class="result-cat">{{rec.cat}}</text>
          <text class="result-score">{{rec.score}}分</text>
        </view>
      </view>

    </view>
  </view>

</view>
