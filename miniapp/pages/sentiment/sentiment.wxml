<!-- pages/sentiment/sentiment.wxml -->
<view class="page">

  <view class="page-header">
    <text class="page-title">情感统计</text>
    <text class="page-subtitle">各品类好评与差评排行</text>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'good' ? 'active good-active' : ''}}"
      bindtap="switchTab" data-tab="good">👍 好评榜</view>
    <view class="tab-item {{activeTab === 'bad' ? 'active bad-active' : ''}}"
      bindtap="switchTab" data-tab="bad">👎 差评榜</view>
  </view>

  <scroll-view class="cat-filter" scroll-x>
    <view
      wx:for="{{catList}}" wx:key="*this"
      class="cat-btn {{activeTab === 'good' ? 'good-btn' : 'bad-btn'}} {{selectedCat === item ? 'active' : ''}}"
      data-cat="{{item}}" bindtap="scrollToCat"
    >{{item}}</view>
  </scroll-view>

  <view wx:if="{{loading}}" class="loading-box"><text>加载中...</text></view>

  <view wx:else class="list">

    <block wx:if="{{activeTab === 'good'}}">
      <view wx:for="{{goodGroups}}" wx:key="cat" class="cat-section" id="good-{{item.catId}}">
        <view class="cat-header">
          <view class="cat-dot good-dot"></view>
          <text class="cat-name">{{item.cat}}</text>
          <text class="cat-count good-count">TOP{{item.list.length}}</text>
        </view>
        <view wx:for="{{item.list}}" wx:for-item="prod" wx:for-index="pidx"
          wx:key="sku_id" class="card"
          data-sku="{{prod.sku_id}}" data-tab="good" bindtap="goDetail">
          <view class="card-top">
            <view class="rank-badge good-badge">{{pidx + 1}}</view>
            <view class="name-wrap"><text class="name">{{prod.sku_id}}</text></view>
            <view class="ratio-badge">
              <text class="ratio-num good-num">{{prod.pos_text}}%</text>
              <text class="ratio-label">好评率</text>
            </view>
          </view>
          <view class="dist-bar">
            <view class="seg seg-pos" style="width:{{prod.pos_bar+'%'}}"></view>
            <view class="seg seg-neu" style="width:{{prod.neu_bar+'%'}}"></view>
            <view class="seg seg-neg" style="width:{{prod.neg_bar+'%'}}"></view>
          </view>
          <view class="dist-numbers">
            <text class="dn-pos">正向 {{prod.pos_text}}%</text>
            <text class="dn-neu">中性 {{prod.neu_text}}%</text>
            <text class="dn-neg">负向 {{prod.neg_text}}%</text>
          </view>
          <view class="meta-row">
            <text class="meta-item">推荐分 {{prod.score_text}}</text>
            <text class="meta-item">评论数 {{prod.absa_comment_count}}</text>
            <text class="meta-item tap-tip">查看方面详情 ›</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:if="{{activeTab === 'bad'}}">
      <view wx:for="{{badGroups}}" wx:key="cat" class="cat-section" id="bad-{{item.catId}}">
        <view class="cat-header">
          <view class="cat-dot bad-dot"></view>
          <text class="cat-name">{{item.cat}}</text>
          <text class="cat-count bad-count">TOP{{item.list.length}}</text>
        </view>
        <view wx:for="{{item.list}}" wx:for-item="prod" wx:for-index="pidx"
          wx:key="sku_id" class="card"
          data-sku="{{prod.sku_id}}" data-tab="bad" bindtap="goDetail">
          <view class="card-top">
            <view class="rank-badge bad-badge">{{pidx + 1}}</view>
            <view class="name-wrap"><text class="name">{{prod.sku_id}}</text></view>
            <view class="ratio-badge">
              <text class="ratio-num bad-num">{{prod.neg_text}}%</text>
              <text class="ratio-label">差评率</text>
            </view>
          </view>
          <view class="dist-bar">
            <view class="seg seg-pos" style="width:{{prod.pos_bar+'%'}}"></view>
            <view class="seg seg-neu" style="width:{{prod.neu_bar+'%'}}"></view>
            <view class="seg seg-neg" style="width:{{prod.neg_bar+'%'}}"></view>
          </view>
          <view class="dist-numbers">
            <text class="dn-pos">正向 {{prod.pos_text}}%</text>
            <text class="dn-neu">中性 {{prod.neu_text}}%</text>
            <text class="dn-neg">负向 {{prod.neg_text}}%</text>
          </view>
          <view class="meta-row">
            <text class="meta-item">推荐分 {{prod.score_text}}</text>
            <text class="meta-item">评论数 {{prod.absa_comment_count}}</text>
            <text class="meta-item tap-tip">查看方面详情 ›</text>
          </view>
        </view>
      </view>
    </block>

  </view>
</view>
