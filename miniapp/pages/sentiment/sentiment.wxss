.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-header {
  background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 45, 61, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a8599;
  line-height: 1.6;
}

.loading {
  text-align: center;
  color: #8a94a6;
  font-size: 28rpx;
  padding: 120rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 26rpx 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 45, 61, 0.06);
  border: 1rpx solid #edf1f7;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2d3d;
  line-height: 1.5;
}

.score-tag {
  min-width: 120rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #eef8f1;
  color: #1ca45c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 800;
  padding: 0 16rpx;
}

.tag-line {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7a8599;
}

.metric-row {
  margin-top: 16rpx;
  background: #f8fafd;
  border-radius: 18rpx;
  padding: 14rpx 18rpx;
}

.metric-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.metric-item + .metric-item {
  margin-top: 10rpx;
}

.metric-label {
  color: #7a8599;
}

.metric-value {
  color: #1f2d3d;
  font-weight: 600;
}

.metric-value.positive {
  color: #1ca45c;
}

.metric-value.negative {
  color: #ef5350;
}

.tap-tip {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: #3b6ff5;
  font-weight: 600;
}