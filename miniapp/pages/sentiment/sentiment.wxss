/* pages/sentiment/sentiment.wxss */
.page { background: #f5f6fa; min-height: 100vh; padding-bottom: 40rpx; }

.page-header {
  background: linear-gradient(135deg, #16a34a, #4a9eff);
  padding: 40rpx 28rpx 32rpx;
}
.page-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; }
.page-subtitle { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

.tab-bar {
  position: sticky;
  top: 0;
  z-index: 101;
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #888; font-weight: 500; }
.tab-item.active { font-weight: 700; }
.tab-item.good-active { color: #16a34a; border-bottom: 4rpx solid #16a34a; }
.tab-item.bad-active  { color: #ff4757; border-bottom: 4rpx solid #ff4757; }

.cat-filter {
  position: sticky;
  top: 88rpx;  /* tab-bar的高度，约88rpx */
  z-index: 100;
  white-space: nowrap;
  background: #fff;
  padding: 12rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.cat-btn { display: inline-block; padding: 8rpx 20rpx; margin-right: 10rpx; border-radius: 20rpx; font-size: 24rpx; background: #f0f0f0; color: #666; }
.cat-btn.active.good-btn { background: #16a34a; color: #fff; }
.cat-btn.active.bad-btn  { background: #ff4757; color: #fff; }

.loading-box { padding: 80rpx; text-align: center; color: #aaa; }
.list { padding-bottom: 20rpx; }

.cat-section { margin-top: 20rpx; }
.cat-header { display: flex; align-items: center; gap: 12rpx; padding: 0 24rpx 12rpx; }
.cat-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.good-dot { background: #16a34a; }
.bad-dot  { background: #ff4757; }
.cat-name { font-size: 30rpx; font-weight: 700; color: #1a1a2e; flex: 1; }
.cat-count { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 10rpx; }
.good-count { color: #16a34a; background: #f0fff4; }
.bad-count  { color: #ff4757; background: #fff0f0; }

.card {
  margin: 0 20rpx 12rpx; background: #fff;
  border-radius: 16rpx; padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.card-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.rank-badge {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  color: #fff; font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.good-badge { background: linear-gradient(135deg, #16a34a, #4a9eff); }
.bad-badge  { background: linear-gradient(135deg, #ff6b6b, #ff4757); }
.name-wrap { flex: 1; overflow: hidden; }
.name { display: block; font-size: 28rpx; font-weight: 600; color: #1a1a2e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ratio-badge { text-align: center; flex-shrink: 0; }
.ratio-num { display: block; font-size: 36rpx; font-weight: 700; }
.good-num { color: #16a34a; }
.bad-num  { color: #ff4757; }
.ratio-label { display: block; font-size: 22rpx; color: #aaa; }

.dist-bar {
  height: 12rpx; border-radius: 6rpx; overflow: hidden;
  display: flex; background: #f0f0f0; margin-bottom: 8rpx;
}
.seg { height: 100%; }
.seg-pos { background: #4a9eff; }
.seg-neu { background: #e0e0e0; }
.seg-neg { background: #ff4757; }

.dist-numbers { display: flex; gap: 20rpx; margin-bottom: 12rpx; }
.dn-pos { font-size: 22rpx; color: #4a9eff; }
.dn-neu { font-size: 22rpx; color: #aaa; }
.dn-neg { font-size: 22rpx; color: #ff4757; }

.meta-row { display: flex; justify-content: space-between; border-top: 1rpx solid #f5f5f5; padding-top: 10rpx; }
.meta-item { font-size: 22rpx; color: #888; }
.tap-tip { color: #4a9eff; }
