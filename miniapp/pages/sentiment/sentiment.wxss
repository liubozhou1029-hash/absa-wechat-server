.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-header {
  background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 45, 61, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a8599;
  line-height: 1.6;
}

.loading {
  text-align: center;
  color: #8a94a6;
  font-size: 28rpx;
  padding: 120rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* ===== 卡片 ===== */
.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 45, 61, 0.06);
  border: 1rpx solid #edf1f7;
}

/* 顶部：商品名 + 推荐分角标 */
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d3d;
  line-height: 1.5;
  word-break: break-all;
}

.score-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 18rpx;
  padding: 12rpx 22rpx;
  min-width: 110rpx;
  flex-shrink: 0;
}

.badge-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
}

.badge-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* ===== 情感分布条 ===== */
.dist-section {
  margin-top: 22rpx;
}

.dist-bar {
  display: flex;
  height: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f2f5;
}

.seg { height: 100%; min-width: 2rpx; }
.seg-pos { background: #16a34a; }
.seg-neu { background: #d1d5db; }
.seg-neg { background: #dc2626; }

.dist-legend {
  display: flex;
  gap: 32rpx;
  margin-top: 14rpx;
}

.leg-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #475467;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-pos { background: #16a34a; }
.dot-neg { background: #dc2626; }

/* ===== 指标网格 ===== */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.metric-cell {
  background: #f8fafd;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cell-label {
  font-size: 22rpx;
  color: #7a8599;
}

.cell-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.cell-value.pos  { color: #16a34a; }
.cell-value.neg  { color: #dc2626; }
.cell-value.absa { color: #0f766e; }

/* ===== 底部跳转提示 ===== */
.tap-tip {
  margin-top: 20rpx;
  text-align: right;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}