/* pages/sentiment_detail/sentiment_detail.wxss */
.page { background: #f5f6fa; min-height: 100vh; padding-bottom: 40rpx; }

.header-card { padding: 40rpx 28rpx 32rpx; }
.good-header { background: linear-gradient(135deg, #16a34a, #4a9eff); }
.bad-header  { background: linear-gradient(135deg, #ff6b6b, #ff4757); }

.cat-badge {
  display: inline-block; background: rgba(255,255,255,0.25);
  color: #fff; font-size: 24rpx; padding: 6rpx 16rpx;
  border-radius: 20rpx; margin-bottom: 12rpx;
}
.title { display: block; font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; line-height: 1.4; }
.score-row { display: flex; gap: 0; }
.score-item { flex: 1; text-align: center; }
.score-big { display: block; font-size: 40rpx; font-weight: 700; color: #fff; }
.score-label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.75); margin-top: 4rpx; }

.card {
  margin: 16rpx 20rpx 0; background: #fff;
  border-radius: 20rpx; padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-title { display: block; font-size: 30rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 6rpx; }
.card-tip { display: block; font-size: 22rpx; color: #aaa; margin-bottom: 16rpx; }

.dist-bar {
  height: 16rpx; border-radius: 8rpx; overflow: hidden;
  display: flex; background: #f0f0f0; margin-bottom: 16rpx;
}
.seg { height: 100%; }
.seg-pos { background: #4a9eff; }
.seg-neu { background: #e0e0e0; }
.seg-neg { background: #ff4757; }

.dist-numbers { display: flex; justify-content: space-around; }
.dn-item { text-align: center; }
.dn-val { display: block; font-size: 32rpx; font-weight: 700; }
.dn-label { display: block; font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.pos-text { color: #4a9eff; }
.neu-text { color: #aaa; }
.neg-text { color: #ff4757; }

.empty { padding: 20rpx; text-align: center; color: #aaa; font-size: 26rpx; }

.aspect-row {
  padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.aspect-row:last-child { border-bottom: none; }

.aspect-left {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 10rpx;
}
.aspect-name { font-size: 28rpx; color: #333; font-weight: 600; }
.aspect-count { font-size: 22rpx; color: #aaa; }

.aspect-bar-wrap {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx;
}
.aspect-bar { flex: 1; height: 14rpx; background: #f0f0f0; border-radius: 7rpx; overflow: hidden; }
.aspect-fill { height: 100%; border-radius: 7rpx; }
.good-fill { background: linear-gradient(90deg, #4a9eff, #7c4dff); }
.bad-fill  { background: linear-gradient(90deg, #ff6b6b, #ff4757); }
.aspect-pct { font-size: 28rpx; font-weight: 700; width: 80rpx; text-align: right; flex-shrink: 0; }

.aspect-detail { display: flex; gap: 20rpx; }
.ad-good { font-size: 22rpx; color: #4a9eff; }
.ad-bad  { font-size: 22rpx; color: #ff4757; }
