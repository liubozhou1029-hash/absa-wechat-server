/* pages/recommend/recommend.wxss */

.container {
  padding: 24rpx;
  background: #f5f6fa;
  min-height: 100vh;
}

/* ── 顶部标题 ── */
.header {
  padding: 32rpx 0 24rpx;
}
.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.subtitle {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

/* ── 输入卡片 ── */
.input-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.input-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.label-hint {
  font-size: 24rpx;
  color: #aaa;
}
.review-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  background: #f8f9fb;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}
.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}
.char-count {
  font-size: 24rpx;
  color: #bbb;
}
.example-btn {
  font-size: 26rpx;
  color: #4a9eff;
  padding: 8rpx 20rpx;
  border: 1rpx solid #4a9eff;
  border-radius: 20rpx;
}

/* ── 数量选择 ── */
.option-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.option-label {
  font-size: 28rpx;
  color: #555;
  margin-right: 20rpx;
}
.topk-btns {
  display: flex;
  gap: 16rpx;
}
.topk-btn {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  background: #eee;
  color: #666;
}
.topk-btn.active {
  background: #4a9eff;
  color: #fff;
}

/* ── 提交按钮 ── */
.submit-btn {
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,158,255,0.3);
}
.submit-btn.disabled {
  opacity: 0.7;
}
.loading-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.dot-loading {
  display: flex;
  gap: 8rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border-radius: 50%;
  animation: blink 1.2s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}

/* ── 结果区块 ── */
.result-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}
.section-icon {
  font-size: 34rpx;
}
.cat-tag {
  margin-left: auto;
  font-size: 24rpx;
  color: #4a9eff;
  background: #eef5ff;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 400;
}

/* ── 偏好列表 ── */
.pref-list { display: flex; flex-direction: column; gap: 16rpx; }
.pref-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.pref-aspect {
  width: 80rpx;
  font-size: 26rpx;
  color: #555;
  flex-shrink: 0;
}
.pref-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}
.pref-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.4s;
}
.pref-bar.pos { background: linear-gradient(90deg, #4a9eff, #7c4dff); }
.pref-bar.neg { background: linear-gradient(90deg, #ff6b6b, #ff4757); }
.pref-score { font-size: 26rpx; width: 80rpx; text-align: right; flex-shrink: 0; }
.pos-text { color: #4a9eff; }
.neg-text { color: #ff4757; }

/* ── 推荐理由 ── */
.reason-box {
  background: #f0f7ff;
  border-left: 6rpx solid #4a9eff;
  border-radius: 0 12rpx 12rpx 0;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.reason-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

/* ── 推荐卡片 ── */
.rec-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}
.rec-card:last-child { border-bottom: none; }
.rec-rank {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rec-info { flex: 1; overflow: hidden; }
.rec-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rec-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.tag-cat   { background: #f0f0ff; color: #7c4dff; }
.tag-pos   { background: #f0fff4; color: #2e7d32; }
.tag-count { background: #fff8e1; color: #f57f17; }
.rec-score {
  text-align: center;
  flex-shrink: 0;
}
.score-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #4a9eff;
}
.score-label {
  display: block;
  font-size: 22rpx;
  color: #aaa;
}
