<!-- pages/index/index.wxml -->
<view class="page">

  <!-- 顶部 hero -->
  <view class="hero-section">
    <view class="hero-top">
      <view class="hero-text">
        <text class="hero-title">商品智能推荐</text>
        <text class="hero-subtitle">基于ABSA方面情感分析的跨品类推荐系统</text>
      </view>
      <view class="avatar-btn" bindtap="goProfile">
        <text class="avatar-icon">👤</text>
        <text class="avatar-label">我的</text>
      </view>
    </view>

    <!-- 数据概览卡片 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">10</text>
        <text class="stat-label">商品品类</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">3276</text>
        <text class="stat-label">收录商品</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">18566</text>
        <text class="stat-label">真实评论</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">29550</text>
        <text class="stat-label">方面分析</text>
      </view>
    </view>
  </view>

  <!-- 智能推荐大卡片 -->
  <view class="recommend-hero-card" bindtap="goRecommend">
    <view class="rec-hero-left">
      <view class="rec-hero-icon">🎯</view>
      <view>
        <text class="rec-hero-title">智能推荐</text>
        <text class="rec-hero-desc">输入您的评论，我们的模型将分析您的偏好</text>
        <text class="rec-hero-desc">为您匹配最适合的商品</text>
      </view>
    </view>
    <view class="rec-hero-btn">
      <text class="rec-hero-btn-text">立即体验</text>
      <text class="rec-hero-arrow">›</text>
    </view>
  </view>

  <!-- 分隔提示 -->
  <view class="divider-section">
    <view class="divider-line"></view>
    <text class="divider-text">想了解我们更多的数据？</text>
    <view class="divider-line"></view>
  </view>

  <!-- 数据展示入口 -->
  <view class="data-section">
    <view class="entry-card data-card" bindtap="goData">
      <view class="entry-left">
        <text class="entry-title">📊 最值得推荐</text>
        <text class="entry-desc">按综合评分排列，各品类Top商品一览</text>
      </view>
      <text class="entry-right">›</text>
    </view>
    <view class="entry-card emotion-card" bindtap="goEmotion">
      <view class="entry-left">
        <text class="entry-title">💚 情感排行榜</text>
        <text class="entry-desc">好评榜与差评榜，各品类情感分布排行</text>
      </view>
      <text class="entry-right">›</text>
    </view>
  </view>

</view>
