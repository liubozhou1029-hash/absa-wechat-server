/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f7f9fc 40%, #eef3f9 100%);
  padding: 0 0 60rpx;
  box-sizing: border-box;
}

/* Hero 区 */
.hero-section {
  background: linear-gradient(135deg, #4a9eff, #7c4dff);
  padding: 60rpx 32rpx 48rpx;
}
.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.hero-text { flex: 1; }
.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
}
.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.8;
}

/* 个人主页按钮 */
.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}
.avatar-icon { font-size: 40rpx; }
.avatar-label { font-size: 22rpx; color: #fff; }

/* 智能推荐大卡片 */
.recommend-hero-card {
  margin: -24rpx 24rpx 0;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(74, 158, 255, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-left: 10rpx solid #f97316;
}
.rec-hero-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}
.rec-hero-icon { font-size: 60rpx; }
.rec-hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2a37;
  margin-bottom: 8rpx;
}
.rec-hero-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.7;
}
.rec-hero-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #f97316, #fb923c);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.rec-hero-btn-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}
.rec-hero-arrow {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

/* 分隔提示 */
.divider-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx 32rpx 24rpx;
}
.divider-line {
  flex: 1;
  height: 1rpx;
  background: #d1d5db;
}
.divider-text {
  font-size: 24rpx;
  color: #9ca3af;
  white-space: nowrap;
}

/* 数据入口区 */
.data-section { padding: 0 24rpx; }

.entry-card {
  background: #fff;
  border-radius: 26rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 55, 0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.entry-left { width: 86%; }
.entry-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2a37;
  line-height: 1.5;
}
.entry-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.8;
}
.entry-right {
  font-size: 32rpx;
  font-weight: 700;
  color: #94a3b8;
}
.data-card  { border-left: 10rpx solid #3b82f6; }
.emotion-card { border-left: 10rpx solid #16a34a; }
/* 数据概览 */
.stats-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 20rpx 0;
  margin-top: 28rpx;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}
.stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
}
.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

/* 推荐结果页新增样式 */
.match-tip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
  background: #f0fff4;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
}
.match-icon { font-size: 22rpx; color: #16a34a; }
.match-text { font-size: 22rpx; color: #16a34a; line-height: 1.5; }

.rec-score-wrap {
  text-align: center;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.detail-hint {
  display: block;
  font-size: 20rpx;
  color: #4a9eff;
  margin-top: 6rpx;
  white-space: nowrap;
}

.retry-btn {
  margin: 20rpx;
  padding: 24rpx;
  text-align: center;
  background: #f5f6fa;
  border-radius: 16rpx;
  border: 2rpx dashed #d1d5db;
  font-size: 28rpx;
  color: #6b7280;
}